# Convex — copy from dashboard.convex.dev after running `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Convex Auth — set to your Convex deployment's HTTP Actions URL
# Format: https://<deployment-name>.convex.site
CONVEX_SITE_URL=

# JWT secret for Convex Auth (generate with: openssl rand -base64 32)
JWT_PRIVATE_KEY=
JWKS=
